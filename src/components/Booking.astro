---
---

<section id="booking" class="py-24 bg-gradient-to-br from-wave-blue via-wave-blue to-wave-blue-dark relative overflow-hidden">

  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
      <path d="M0 200 C240 100, 480 300, 720 200 C960 100, 1200 300, 1440 200 L1440 400 L0 400 Z" fill="#E8638B"/>
    </svg>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-wave-pink/20 border border-wave-pink/30 mb-6">
      <svg class="w-8 h-8 text-wave-peach" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
    </div>

    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4 leading-tight">
      Want to have a chat?
    </h2>
    <p class="text-lg text-blue-100 max-w-xl mx-auto mb-10 leading-relaxed">
      I'd love to hear about where you're at and what you're working towards.
      Book a free 15-minute call and we can figure out the best way I can help.
    </p>

    <!-- Calendly CTA -->
    <!-- Replace href with your real Calendly URL, e.g. https://calendly.com/chelsea-wavecoaching -->
    <a
      href="https://calendly.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 bg-wave-pink hover:bg-wave-pink-dark text-white font-bold text-lg px-10 py-4 rounded-xl shadow-2xl hover:shadow-wave-pink/40 transition-all duration-200"
      data-calendly-placeholder="true"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Book a Session
    </a>

    <!-- Reassurance -->
    <p class="text-blue-200 text-sm mt-5">
      Free call &bull; No pressure, no commitment &bull; I'll get back to you within 24 hours
    </p>

  </div>
</section>

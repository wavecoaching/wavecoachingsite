---
import PricingCard from './PricingCard.astro';

const plans = [
  {
    title: '1-on-1 Swim Lesson',
    price: '$70',
    period: 'session',
    description: 'Private Swim coaching in Redcliffe Area pool or open water.',
    features: [
      '60-minute private session',
      'Pool or open water venue',
      'Personalised drill focus',
      'Progress notes after each session',
      'Instant feedback and technique adjustments during the session',
    ],
    calLink: 'chelsea-triwave/1-1-swim-lesson',
    ctaLabel: 'Book Now',
  },
  {
    title: 'Swim Analysis (In-Person)',
    price: '$100',
    period: 'analysis',
    description: 'In-person video stroke analysis with video feedback and drill plan.',
    features: [
      'Underwater + above-water video',
      'Frame-by-frame breakdown',
      'Video feedback with visual annotations',
      'Conducted at Redcliffe Area pool or open water',
      'Instant feedback and technique adjustments during the session',
    ],
    calLink: 'chelsea-triwave/swim-analysis',
    ctaLabel: 'Book Now',
  },
  {
    title: 'Remote Swim Analysis',
    price: '$50',
    period: 'analysis',
    description: 'Send your swim footage and receive a full stroke analysis remotely.',
    features: [
      'Submit your own video footage',
      'Frame-by-frame breakdown',
      'Video feedback with visual annotations',
      'Drill plan tailored to your focus areas of improvement',
      'Email delivery within 72 hours',
    ],
    stripeUrl: 'https://book.stripe.com/8x2aERb8N3jN88ebgH1B60b',
    ctaLabel: 'Book Now',
  },
  {
    title: 'Online Triathlon Coaching',
    price: '$30',
    period: 'week',
    description: 'Full triathlon coaching for Ironman, Half-Ironman & Olympic distance.',
    features: [
      'Personalised weekly training plan',
      'TrainingPeaks delivery + feedback',
      'Swim, bike & run programming',
      'Race-week strategy + support',
      '24/7 access to me for questions and feedback',
    ],
    stripeUrl: 'https://buy.stripe.com/9B6bIV4Kp07B9cidoP1B606',
    ctaLabel: 'Start Now',
  },
];
---

<section id="pricing" class="py-20 bg-wave-peach-light">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-wave-blue-dark mt-2">Coaching Pricing</h2>
      <p class="mt-4 text-wave-gray max-w-xl mx-auto">
        Transparent pricing, no lock-in contracts.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 items-start">
      {plans.map(plan => (
        <PricingCard {...plan} />
      ))}
    </div>

    <!-- Note -->
    <p class="text-center text-xs text-wave-gray mt-8 opacity-70">
      Secure payment powered by Stripe.
    </p>
  </div>
</section>

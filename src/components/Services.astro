---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    accent: 'blue' as const,
    icon: 'M15 10l4.553-2.069A1 1 0 0121 8.87V15.13a1 1 0 01-1.447.894L15 14M3 8h12a2 2 0 012 2v4a2 2 0 01-2 2H3a2 2 0 01-2-2v-4a2 2 0 012-2z',
    title: 'Swimming Services',
    description: '1:1 swim analysis and private swim lessons tailored to where you\'re at. I\'ll film your stroke, break it down frame by frame, and give you a clear plan to work on.',
    features: [
      '1:1 swim analysis (in-person & remote)',
      '1:1 private swim lessons',
      'Underwater & above-water video',
      'Frame-by-frame stroke breakdown',
      'Pool technique & open water skills',
      'All levels genuinely welcome',
    ],
    ctaLabel: 'View Pricing',
    ctaHref: '#pricing',
  },
  {
    accent: 'peach' as const,
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    title: 'Online Triathlon Coaching',
    description: 'Personalised training programs for Olympic, 70.3, or Full Ironman distances.',
    features: [
      'Olympic, 70.3 & Full Ironman plans',
      'Weekly plans via TrainingPeaks',
      'Swim, bike & run programming',
      'Race-week strategy & support',
      '24/7 access to me for questions and feedback',
    ],
    ctaLabel: 'Book Now',
    ctaHref: 'https://buy.stripe.com/9B6bIV4Kp07B9cidoP1B606',
  },
];
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="text-wave-pink font-semibold text-sm uppercase tracking-widest">How I Can Help</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-wave-blue-dark mt-2">What I Offer</h2>
      <p class="mt-4 text-wave-gray max-w-xl mx-auto">
        Whether you want to nail your technique, build confidence in the water, or train for your next race, I'd love to help.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {services.map(service => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>

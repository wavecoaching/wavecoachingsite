---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    accent: 'blue' as const,
    icon: 'M15 10l4.553-2.069A1 1 0 0121 8.87V15.13a1 1 0 01-1.447.894L15 14M3 8h12a2 2 0 012 2v4a2 2 0 01-2 2H3a2 2 0 01-2-2v-4a2 2 0 012-2z',
    title: 'Swim Analysis',
    description: 'I\'ll film your stroke above and below the water, break it down frame by frame, and give you a clear plan to work on. It\'s one of the fastest ways to see real improvement.',
    features: [
      'Underwater & above-water video',
      'Frame-by-frame stroke breakdown',
      'Personalised drill plan',
      'Written report + video feedback',
      'Follow-up comparison available',
    ],
    ctaLabel: 'Get in Touch',
    ctaHref: '#booking',
  },
  {
    accent: 'pink' as const,
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    title: '1-on-1 Swim Sessions',
    description: 'Private sessions at Redcliffe pools or open water, completely tailored to where you\'re at. Whether you\'re just starting out or chasing a PB, we\'ll work on what matters most to you.',
    features: [
      'All levels genuinely welcome',
      'Pool technique & open water skills',
      'Race-start and sighting practice',
      'Flexible scheduling around your life',
      'Progress tracking between sessions',
    ],
    ctaLabel: 'Book a Session',
    calLink: 'chelsea-triwave/1-1-swim-lesson',
  },
  {
    accent: 'peach' as const,
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    title: 'Online Triathlon Coaching',
    description: 'Personalised training programs for Olympic, 70.3, or Full Ironman distances &mdash; built around your life, because I know most of us have jobs, families, and limited hours.',
    features: [
      'Olympic, 70.3 & Full Ironman plans',
      'Weekly plans via TrainingPeaks',
      'Regular video check-ins',
      'Swim, bike & run integration',
      'Race-week strategy & support',
    ],
    ctaLabel: 'Book Now',
    ctaHref: 'https://buy.stripe.com/5kQ00d1yd07B3RYbgH1B607',
  },
];
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="text-wave-pink font-semibold text-sm uppercase tracking-widest">How I Can Help</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-wave-blue-dark mt-2">What I Offer</h2>
      <p class="mt-4 text-wave-gray max-w-xl mx-auto">
        Whether you want to nail your technique, build open water confidence, or train for your next race &mdash; I'd love to help.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map(service => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>
